# GitHub Tokens (add multiple for rotation)
GITHUB_TOKEN=YOUR-PRIMARY-GITHUB-PAT-HERE
GITHUB_TOKEN_2=BACKUP-GITHUB-PAT-HERE
GITHUB_TOKEN_3=THIRD-GITHUB-PAT-HERE

# Dograh Database Connection (from docker-compose)
POSTGRES_CONNECTION=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/postgres

# Redis for caching/relationship memory
REDIS_URL=redis://:CHANGE_ME_REDIS_SECRET@redis:6379

# WhatsApp settings
PROCESS_UNANSWERED_MINUTES=60
CHAT_HISTORY_DAYS=7