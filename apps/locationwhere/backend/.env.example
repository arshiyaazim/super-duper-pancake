# Server Config
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/location_where?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT — REQUIRED: generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# AWS S3
AWS_ACCESS_KEY_ID="your_aws_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET="employee-recordings-bucket"

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_PATH=""
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="your-client-email"
FIREBASE_PRIVATE_KEY="your-private-key"

# AES Encryption
ENCRYPTION_KEY="32_char_long_encryption_key_here"
ENCRYPTION_IV="16_char_long_iv_here"

# SMS Gateway (Android smsgateway app only)
# Do not configure external SMS providers here. The server returns reply payloads
# for the Android gateway; it must not send SMS directly.

# === Admin SMS onboarding phone (no country code prefix) ===
ADMIN_ONBOARDING_PHONE=01958122300

# === APK public download URL ===
APK_DOWNLOAD_URL=https://locationwhere.iamazim.com/downloads/app-debug.apk

# === REQUIRED: generate with: openssl rand -hex 32 ===
SMS_GATEWAY_SECRET=

# Optional: sync SMS-onboarded employees into fazle-core wbom_employees table
FAZLE_CORE_SYNC_ENABLED=true
FAZLE_CORE_EMPLOYEE_TABLE=wbom_employees
