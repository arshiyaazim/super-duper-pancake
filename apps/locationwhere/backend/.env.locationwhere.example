PORT=8310
NODE_ENV=production

# Temporary shared-Postgres mode with isolated schema
# PostgreSQL host: 172.20.0.3
# Redis host: 172.20.0.5
DATABASE_URL="postgresql://postgres:CHANGE_ME@172.20.0.3:5432/postgres?schema=locationwhere"
REDIS_URL="redis://:CHANGE_ME@172.20.0.5:6379/15"
REDIS_OPTIONAL=true

JWT_ACCESS_SECRET="CHANGE_ME_ACCESS_SECRET"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH_SECRET"

AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-southeast-1"
AWS_S3_BUCKET=""

FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

ENCRYPTION_KEY="01234567890123456789012345678901"
ENCRYPTION_IV="0123456789012345"

# Android smsgateway app only. Do not configure external SMS providers here.
ADMIN_ONBOARDING_PHONE=01958122300
APK_DOWNLOAD_URL=https://locationwhere.iamazim.com/downloads/app-debug.apk
SMS_GATEWAY_SECRET="CHANGE_ME_GATEWAY_SECRET"

# Optional: sync SMS-onboarded employees into fazle-core wbom_employees table
FAZLE_CORE_SYNC_ENABLED=true
FAZLE_CORE_EMPLOYEE_TABLE=wbom_employees
