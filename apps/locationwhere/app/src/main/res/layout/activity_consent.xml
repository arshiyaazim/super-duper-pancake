<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/consentTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monitoring Consent"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:id="@+id/consentScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/consentTitle"
        app:layout_constraintBottom_toTopOf="@id/agreeCheckbox">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This application monitors your device for company security policies. By agreeing, you consent to:\n\n1. Real-time location tracking\n2. Call log monitoring and recording\n3. SIM card change detection\n4. Remote device management (lock/wipe)\n\nThis data is strictly for company use and compliance with the Digital Security Act."
            android:textSize="16sp" />
    </ScrollView>

    <CheckBox
        android:id="@+id/agreeCheckbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="I acknowledge and agree to these terms"
        app:layout_constraintBottom_toTopOf="@id/continueBtn"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/continueBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Confirm and Start Monitoring"
        android:enabled="false"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
